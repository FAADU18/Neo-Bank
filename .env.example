# NeoBankX Vercel Deployment Environment Variables
# Copy this file to .env and fill in the actual values

# ==========================================
# FLASK CONFIGURATION
# ==========================================
FLASK_ENV=production

# Secret key for Flask sessions (generate a strong random key)
SECRET_KEY=your-super-secret-key-change-this-in-production

# ==========================================
# JWT CONFIGURATION
# ==========================================
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# PostgreSQL connection string for production
# Format: postgresql://username:password@host:port/database
# Get this from your Supabase or Neon PostgreSQL provider
DATABASE_URL=postgresql://user:password@host:5432/neobank_db

# ==========================================
# CORS CONFIGURATION
# ==========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://neobankx.vercel.app,http://localhost:3000,http://localhost:5174

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# The base URL for API calls from the frontend
# For Vercel, use relative path /api
VITE_API_URL=/api
