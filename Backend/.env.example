# NeoBankX Backend Configuration
# Copy this file to .env and update with your values

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Database
# Local dev only (SQLite file in Backend folder):
DATABASE_URL=sqlite:///banking_app.db
# Vercel production — use PostgreSQL (do NOT use sqlite:/// on Vercel):
# DATABASE_URL=postgresql://user:password@host:5432/neobank_db
# For PostgreSQL: postgresql://user:password@localhost:5432/neobankx_db
# For MySQL: mysql+pymysql://user:password@localhost:3306/neobankx_db

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production-12345678

# Database (example for Supabase/Postgres)
# Replace with your Supabase DATABASE_URL, e.g.:
# postgresql://username:password@db.host.supabase.co:5432/neobankx_db
DATABASE_URL=

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Fraud Detection Thresholds
HIGH_AMOUNT_THRESHOLD=50000
RAPID_TRANSFER_THRESHOLD=5
DAILY_LIMIT=500000

# Email Configuration (for future notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
